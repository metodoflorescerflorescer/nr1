<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<title>NR1 Além da Norma™ — Guia Prático para Empresários | Katti Elleres</title>
<meta name="description" content="A partir de maio de 2026, a nova NR1 torna obrigatória a gestão de riscos psicossociais. Prepare sua empresa e evite multas de até R$805 por trabalhador. Livro NR1 Além da Norma.">
<meta name="keywords" content="NR1, riscos psicossociais, saúde mental no trabalho, compliance, gestão de riscos, Katti Elleres">
<meta property="og:title" content="NR1 Além da Norma™ — Guia Prático para Empresários">
<meta property="og:description" content="Prepare sua empresa para a nova NR1. Evite multas de até R$805 por trabalhador. Livro por R$45.">
<meta property="og:image" content="assets/hero-book.png">
<link rel="icon" href="assets/logo.png" type="image/png">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500;1,600&family=Montserrat:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<style>
/* ═══════════════════════════════════════════
   RESET & ROOT
   ═══════════════════════════════════════════ */
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
:root{
  --cream:#F4EFE6;--cream-mid:#EDE5D4;--cream-dark:#E5DBC8;
  --black:#181818;--charcoal:#2C2C2C;
  --gold:#B89530;--gold-light:#D4AF55;--gold-pale:#E8D99A;
  --red:#C0392B;--red-dark:#96281B;
  --green:#27AE60;
  --white:#FFFFFF;
  --text:#2C2C2C;--text-mid:#5A5A5A;
  --space-xs:8px;--space-sm:16px;--space-md:24px;--space-lg:40px;--space-xl:64px;--space-2xl:100px;
  --max-w:1200px;--urgency-h:44px;
  --font-serif:'Cormorant Garamond',Georgia,serif;
  --font-sans:'Montserrat',system-ui,sans-serif;
}
html{scroll-behavior:smooth;scroll-padding-top:var(--urgency-h)}
body{font-family:var(--font-sans);background:var(--cream);color:var(--text);overflow-x:hidden;-webkit-font-smoothing:antialiased;-moz-osx-font-smoothing:grayscale;line-height:1.5;width:100%}
img{max-width:100%;height:auto;display:block}
a{color:inherit;text-decoration:none}
button{cursor:pointer;border:none;background:none;font-family:inherit}
*,*::before,*::after{max-width:100%}

/* ═══════════════════════════════════════════
   KEYFRAMES
   ═══════════════════════════════════════════ */
@keyframes slideDown{from{opacity:0;transform:translateY(-100%)}to{opacity:1;transform:translateY(0)}}
@keyframes fadeInUp{from{opacity:0;transform:translateY(32px)}to{opacity:1;transform:translateY(0)}}
@keyframes fadeInLeft{from{opacity:0;transform:translateX(-32px)}to{opacity:1;transform:translateX(0)}}
@keyframes fadeInRight{from{opacity:0;transform:translateX(32px)}to{opacity:1;transform:translateX(0)}}
@keyframes fadeIn{from{opacity:0}to{opacity:1}}
@keyframes scaleIn{from{opacity:0;transform:scale(.9)}to{opacity:1;transform:scale(1)}}
@keyframes goldGrow{from{width:0;opacity:0}to{width:60px;opacity:1}}
@keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-10px)}}
@keyframes pulse{0%,100%{transform:scale(1)}50%{transform:scale(1.03)}}
@keyframes pulseDot{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.5;transform:scale(1.6)}}
@keyframes glowPulse{0%,100%{box-shadow:0 0 20px rgba(184,149,48,.12)}50%{box-shadow:0 0 44px rgba(184,149,48,.32)}}
@keyframes countdown{0%,100%{opacity:1}50%{opacity:.6}}
@keyframes logoEntry{0%{opacity:0;transform:translateY(12px) scale(.94)}60%{opacity:1;transform:translateY(-2px) scale(1.02)}100%{opacity:1;transform:translateY(0) scale(1)}}
@keyframes shimmerGold{0%{filter:brightness(1) drop-shadow(0 0 0 rgba(184,149,48,0))}50%{filter:brightness(1.12) drop-shadow(0 0 12px rgba(184,149,48,.3))}100%{filter:brightness(1) drop-shadow(0 0 0 rgba(184,149,48,0))}}

/* ═══════════════════════════════════════════
   SCROLL REVEAL
   ═══════════════════════════════════════════ */
.sr{opacity:0;transform:translateY(28px);transition:opacity .7s cubic-bezier(.25,.8,.25,1),transform .7s cubic-bezier(.25,.8,.25,1)}
.sr-left{opacity:0;transform:translateX(-28px);transition:opacity .7s cubic-bezier(.25,.8,.25,1),transform .7s cubic-bezier(.25,.8,.25,1)}
.sr-right{opacity:0;transform:translateX(28px);transition:opacity .7s cubic-bezier(.25,.8,.25,1),transform .7s cubic-bezier(.25,.8,.25,1)}
.sr.in,.sr-left.in,.sr-right.in{opacity:1;transform:none}
.d1{transition-delay:.1s}.d2{transition-delay:.2s}.d3{transition-delay:.3s}.d4{transition-delay:.4s}
.d5{transition-delay:.5s}.d6{transition-delay:.6s}.d7{transition-delay:.7s}.d8{transition-delay:.8s}

/* ═══════════════════════════════════════════
   1. URGENCY BAR — sticky top
   ═══════════════════════════════════════════ */
.urgency-bar{
  background:var(--red);color:#fff;text-align:center;
  padding:12px 20px;font-size:11px;font-weight:700;letter-spacing:2px;
  position:sticky;top:0;z-index:200;
  height:var(--urgency-h);display:flex;align-items:center;justify-content:center;
  animation:slideDown .5s ease both;
}
.urgency-bar em{color:var(--gold-pale);font-style:normal;font-weight:800}

/* ═══════════════════════════════════════════
   2. HERO
   ═══════════════════════════════════════════ */
.hero{
  background:var(--cream);position:relative;overflow:hidden;
  padding:48px 16px var(--space-lg);
}
/* Subtle diagonal texture overlay */
.hero::before{
  content:'';position:absolute;inset:0;
  background-image:repeating-linear-gradient(-45deg,transparent,transparent 40px,rgba(184,149,48,.02) 40px,rgba(184,149,48,.02) 41px);
  z-index:0;pointer-events:none;
}
.hero-inner{
  position:relative;z-index:2;max-width:1400px;margin:0 auto;
  display:flex;flex-direction:column;gap:var(--space-lg);
}

/* Logo */
.hero-logo{width:220px;animation:logoEntry .8s cubic-bezier(.34,1.56,.64,1) .1s both}
.hero-logo img{width:100%;height:auto;animation:shimmerGold 4s ease-in-out 2s infinite;transition:transform .3s,filter .3s}
.hero-logo img:hover{transform:scale(1.06) translateY(-2px);animation-play-state:paused;filter:brightness(1.1) drop-shadow(0 4px 14px rgba(184,149,48,.4))!important}

/* Urgency badge */
.hero-badge{
  display:inline-flex;align-items:center;gap:var(--space-xs);
  background:var(--red);color:#fff;
  font-size:9px;font-weight:700;letter-spacing:2px;
  padding:var(--space-xs) var(--space-md);
  animation:fadeInUp .7s ease .2s both;align-self:flex-start;
}
.hero-badge svg{width:14px;height:14px;stroke:currentColor;fill:none;stroke-width:2}

/* Title block */
.hero-title{animation:fadeInLeft .8s ease .25s both}
.hero-nr1{
  font-family:var(--font-serif);font-size:clamp(60px,16vw,140px);
  font-weight:300;line-height:.82;color:var(--black);letter-spacing:-2px;
}
.hero-nr1 span{color:var(--gold);font-style:italic}
.hero-subtitle{
  font-size:clamp(8px,2.5vw,13px);font-weight:700;letter-spacing:clamp(3px,1.5vw,7px);
  color:var(--charcoal);margin-top:var(--space-xs);
}
.gold-bar{height:2px;background:var(--gold);width:0;animation:goldGrow .8s ease .55s forwards;margin-top:var(--space-sm)}
.hero-desc{
  font-family:var(--font-serif);font-size:clamp(16px,3.5vw,19px);
  color:var(--text-mid);line-height:1.75;max-width:480px;
  animation:fadeInUp .7s ease .45s both;margin-top:var(--space-sm);
}
.hero-desc strong{color:var(--red);font-weight:600}

/* Price block */
.price-block{
  background:var(--black);padding:var(--space-md) 24px;max-width:100%;
  position:relative;border-radius:2px;margin-top:var(--space-sm);
  animation:fadeInUp .7s ease .5s both;
}
.price-block::before{
  content:'OFERTA EXCLUSIVA';position:absolute;top:-12px;left:16px;
  background:var(--red);color:#fff;font-size:9px;font-weight:700;letter-spacing:2px;padding:5px 14px;z-index:5;
}
.price-old{
  font-family:var(--font-serif);font-size:18px;color:rgba(255,255,255,.35);
  text-decoration:line-through;display:inline-block;margin-bottom:4px;
}
.price-new{
  font-family:var(--font-serif);font-size:48px;font-weight:600;
  color:var(--gold-light);line-height:1;
}
.price-new small{font-size:14px;font-weight:400;color:rgba(255,255,255,.45);display:block;margin-top:4px}
.price-save{font-size:10px;font-weight:700;letter-spacing:1.5px;color:var(--green);margin-top:var(--space-xs)}

/* Trust icons */
.hero-icons{display:flex;align-items:flex-start;gap:0;animation:fadeInUp .7s ease .55s both;flex-wrap:wrap}
.hi-item{display:flex;flex-direction:column;align-items:center;gap:8px;text-align:center;flex:1;min-width:80px}
.hi-circle{
  width:44px;height:44px;border:1.5px solid var(--gold);border-radius:50%;
  display:flex;align-items:center;justify-content:center;transition:background .3s,transform .3s;
}
.hi-circle:hover{background:var(--gold);transform:scale(1.06)}
.hi-circle:hover svg{stroke:#fff}
.hi-circle svg{width:18px;height:18px;stroke:var(--gold);fill:none;stroke-width:1.5}
.hi-label{font-size:8px;font-weight:700;letter-spacing:1.2px;color:var(--text-mid);max-width:80px;line-height:1.4}
.hi-sep{width:1px;height:32px;background:rgba(184,149,48,.3);margin:5px var(--space-sm) 0;flex-shrink:0}

/* CTA */
.cta-wrap{animation:fadeInUp .7s ease .65s both;margin-top:var(--space-sm)}
.cta{
  display:inline-flex;align-items:center;gap:14px;
  background:var(--gold);color:#fff;
  font-size:11px;font-weight:700;letter-spacing:3.5px;
  padding:16px 36px;text-decoration:none;
  position:relative;overflow:hidden;transition:box-shadow .3s;
  animation:pulse 2.5s ease-in-out 2s infinite;min-height:48px;min-width:44px;
}
.cta::before{
  content:'';position:absolute;inset:0;background:var(--black);
  transform:translateX(-101%);transition:transform .5s cubic-bezier(.77,0,.18,1);
}
.cta:hover::before{transform:translateX(0)}
.cta:hover{box-shadow:0 10px 36px rgba(0,0,0,.25);animation-play-state:paused}
.cta span,.cta svg{position:relative;z-index:1}
.cta svg{width:16px;height:16px;stroke:currentColor;fill:none;stroke-width:2;transition:transform .3s}
.cta:hover svg{transform:translateX(4px)}
.cta-sub{font-size:9px;font-weight:500;letter-spacing:1px;color:var(--text-mid);margin-top:var(--space-sm);animation:fadeInUp .7s ease .75s both}

/* Hero book image (mobile-first: shown on mobile) */
.hero-book-mobile{text-align:center;padding-top:var(--space-md);position:relative;z-index:3}
.hero-book-mobile img{
  max-width:260px;margin:0 auto;
  filter:drop-shadow(6px 12px 24px rgba(0,0,0,.14));
  animation:scaleIn .9s cubic-bezier(.25,.8,.25,1) .8s both,float 5s ease-in-out 2s infinite;
}
.hero-person-mobile{
  display:flex;align-items:center;gap:var(--space-sm);margin-bottom:var(--space-md);
}
.hero-person-mobile img{
  width:48px;height:48px;border-radius:50%;object-fit:cover;object-position:center top;border:2px solid var(--gold);flex-shrink:0;
}
.hero-person-mobile span{font-size:12px;font-weight:600;color:var(--text);line-height:1.3}
.hero-person-mobile small{display:block;font-size:10px;font-weight:400;color:var(--text-mid)}

/* Desktop hero-right (hidden on mobile) */
.hero-right{display:none;position:relative;z-index:2;min-height:500px}
.hero-person{
  position:absolute;bottom:0;right:0;width:70%;height:94%;
  object-fit:cover;object-position:center top;animation:fadeIn 1s ease .3s both;z-index:2;
}
.hero-book{
  position:absolute;bottom:10%;left:8%;width:36%;object-fit:contain;
  filter:drop-shadow(8px 16px 32px rgba(0,0,0,.18));
  animation:scaleIn 1s cubic-bezier(.25,.8,.25,1) .6s both,float 5s ease-in-out 2s infinite;z-index:4;
}

/* ═══════════════════════════════════════════
   3. SOCIAL PROOF BAR
   ═══════════════════════════════════════════ */
.proof-bar{
  background:var(--black);border-top:1px solid var(--gold);
  padding:var(--space-md) 16px;
  display:grid;grid-template-columns:1fr 1fr;gap:16px;text-align:center;
}
.proof-item{padding:var(--space-xs);position:relative}
.proof-number{font-family:var(--font-serif);font-size:28px;font-weight:600;color:var(--gold-light);line-height:1}
.proof-label{font-size:8px;font-weight:600;letter-spacing:1.5px;color:rgba(255,255,255,.4);margin-top:6px;line-height:1.4}

/* ═══════════════════════════════════════════
   4. PROBLEM SECTION (DOR)
   ═══════════════════════════════════════════ */
.problem{
  background:var(--cream-dark);padding:var(--space-lg) 16px var(--space-xl);
  text-align:center;max-width:100%;
}
.problem .sec-tag{font-size:9px;font-weight:700;letter-spacing:4px;color:var(--red);display:block;margin-bottom:12px}
.problem .sec-title{font-family:var(--font-serif);font-size:clamp(24px,6vw,44px);font-weight:400;color:var(--black);margin-bottom:10px;line-height:1.15}
.problem .sec-line{width:50px;height:2px;background:var(--red);margin:0 auto var(--space-lg)}
.problem-grid{display:grid;grid-template-columns:1fr;gap:var(--space-sm);max-width:var(--max-w);margin:0 auto}
.problem-card{
  background:var(--cream);padding:var(--space-lg) var(--space-md);text-align:left;
  border-left:3px solid var(--red);border-radius:2px;
  transition:transform .35s,box-shadow .35s;box-shadow:0 4px 16px rgba(0,0,0,.04);
}
.problem-card:hover{transform:translateY(-4px);box-shadow:0 16px 36px rgba(0,0,0,.07)}
.problem-card .pc-icon{
  width:44px;height:44px;background:rgba(192,57,43,.07);border-radius:50%;
  display:flex;align-items:center;justify-content:center;margin-bottom:var(--space-sm);flex-shrink:0;
}
.problem-card .pc-icon svg{width:20px;height:20px;stroke:var(--red);fill:none;stroke-width:1.5}
.problem-card h4{font-size:10px;font-weight:700;letter-spacing:2px;color:var(--text);margin-bottom:8px}
.problem-card p{font-family:var(--font-serif);font-size:16px;color:var(--text-mid);line-height:1.65}
.problem-footer{
  max-width:680px;margin:var(--space-lg) auto 0;
  font-family:var(--font-serif);font-size:17px;color:var(--red-dark);
  line-height:1.65;font-style:italic;
}

/* ═══════════════════════════════════════════
   5. QUOTE BAND
   ═══════════════════════════════════════════ */
.quote-band{
  background:var(--black);padding:var(--space-lg) 16px;
  display:grid;grid-template-columns:1fr;gap:var(--space-md);
  align-items:center;position:relative;overflow:hidden;max-width:100%;
}
.quote-band::before{
  content:'';position:absolute;width:300px;height:300px;top:-80px;right:-40px;
  border-radius:50%;border:1px solid rgba(184,149,48,.1);pointer-events:none;
}
.qb-left h2{font-family:var(--font-serif);font-size:clamp(22px,6vw,36px);font-weight:500;color:#fff;line-height:1.25}
.qb-gold{color:var(--gold-light);font-style:italic}
.qb-sep{
  width:50px;height:2px;background:var(--gold);margin:0 auto;
  position:relative;
}
.qb-sep::before{
  content:'';position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);
  width:6px;height:6px;background:var(--gold);border-radius:50%;
  box-shadow:0 0 10px rgba(184,149,48,.4);
}
.qb-right p{font-family:var(--font-serif);font-size:clamp(16px,3.5vw,20px);font-weight:300;color:rgba(255,255,255,.7);line-height:1.85}

/* ═══════════════════════════════════════════
   6. ABOUT AUTHOR
   ═══════════════════════════════════════════ */
.about{
  background:var(--cream);padding:var(--space-lg) 16px var(--space-xl);
  max-width:1400px;margin:0 auto;
}
.about-photo-mobile{text-align:center;margin-bottom:var(--space-md)}
.about-photo-mobile img{
  width:100px;height:100px;border-radius:50%;object-fit:cover;object-position:center top;
  border:2px solid var(--gold);margin:0 auto;
}
.about-tag{font-size:9px;font-weight:700;letter-spacing:4px;color:var(--gold);margin-bottom:12px;display:block}
.about-tag::after{content:'';display:block;width:36px;height:2px;background:var(--gold);margin-top:8px}
.about-mid p{font-family:var(--font-serif);font-size:17px;color:var(--text-mid);line-height:1.85;margin-bottom:16px}
.about-sig{margin-top:8px}
.about-sig img{height:48px;width:auto;opacity:.9;filter:drop-shadow(0 1px 4px rgba(184,149,48,.12));transition:filter .3s,transform .3s}
.about-sig img:hover{filter:drop-shadow(0 2px 10px rgba(184,149,48,.35));transform:translateY(-2px)}

/* Desktop-only about photo */
.about-photo{display:none;position:relative}
.about-photo img{width:300px;height:380px;object-fit:cover;object-position:center top;border-radius:3px;display:block}
.about-photo-accent{position:absolute;bottom:-16px;right:-16px;width:78%;height:78%;border:2px solid var(--gold);border-radius:3px;z-index:-1;transition:transform .4s}
.about-photo:hover .about-photo-accent{transform:translate(4px,4px)}

.about-benefits{display:flex;flex-direction:column;gap:20px;margin-top:var(--space-lg)}
.bitem{display:flex;gap:14px;align-items:flex-start}
.bcheck{
  width:22px;height:22px;flex-shrink:0;border:1.5px solid var(--gold);border-radius:50%;
  display:flex;align-items:center;justify-content:center;margin-top:2px;transition:background .3s;
}
.bitem:hover .bcheck{background:var(--gold)}
.bitem:hover .bcheck svg{stroke:#fff}
.bcheck svg{width:10px;height:10px;stroke:var(--gold);fill:none;stroke-width:2.5}
.btitle{font-size:10px;font-weight:700;letter-spacing:2px;color:var(--text);margin-bottom:3px}
.bdesc{font-family:var(--font-serif);font-size:16px;color:var(--text-mid);line-height:1.55}

/* ═══════════════════════════════════════════
   7. BOOK FEATURE SECTION
   ═══════════════════════════════════════════ */
.book-section{
  background:var(--cream-mid);padding:var(--space-lg) 16px var(--space-xl);
  max-width:1400px;margin:0 auto;
}
.book-img-wrap{position:relative;display:flex;justify-content:center;margin-bottom:var(--space-lg)}
.book-img-wrap img{
  max-width:320px;border-radius:4px;
  box-shadow:0 20px 44px rgba(0,0,0,.1),0 6px 14px rgba(0,0,0,.06);
  transition:transform .5s,box-shadow .5s;
}
.book-img-wrap:hover img{transform:translateY(-6px);box-shadow:0 28px 56px rgba(0,0,0,.14),0 10px 20px rgba(0,0,0,.08)}
.book-text h2{font-family:var(--font-serif);font-size:clamp(26px,6vw,50px);font-weight:400;color:var(--black);line-height:1.1;margin-bottom:18px}
.book-gold{color:var(--gold);font-style:italic}
.book-contents{list-style:none;margin-bottom:var(--space-lg)}
.book-contents li{
  display:flex;align-items:flex-start;gap:12px;
  font-family:var(--font-serif);font-size:16px;color:var(--text-mid);line-height:1.6;
  padding:var(--space-xs) 0;border-bottom:1px solid rgba(184,149,48,.15);
}
.book-contents li:last-child{border-bottom:none}
.book-contents li svg{width:15px;height:15px;stroke:var(--gold);fill:none;stroke-width:2;flex-shrink:0;margin-top:5px}

/* ═══════════════════════════════════════════
   8. BENEFITS CARDS
   ═══════════════════════════════════════════ */
.cards-section{background:var(--cream);padding:var(--space-lg) 16px var(--space-xl);text-align:center;max-width:100%}
.sec-tag{font-size:9px;font-weight:700;letter-spacing:4px;color:var(--gold);display:block;margin-bottom:12px}
.sec-title{font-family:var(--font-serif);font-size:clamp(24px,6vw,44px);font-weight:400;color:var(--black);margin-bottom:10px}
.sec-line{width:50px;height:2px;background:var(--gold);margin:0 auto var(--space-lg)}
.cards-grid{display:grid;grid-template-columns:1fr;gap:var(--space-md);max-width:var(--max-w);margin:0 auto;align-items:stretch}
.card{
  background:var(--cream-mid);padding:var(--space-lg) var(--space-md);
  display:flex;flex-direction:column;align-items:center;gap:14px;
  position:relative;overflow:hidden;transition:transform .35s,box-shadow .35s;
  cursor:default;border-radius:2px;box-shadow:0 4px 16px rgba(0,0,0,.04);
}
.card::before{
  content:'';position:absolute;top:0;left:0;right:0;height:3px;
  background:var(--gold);transform:scaleX(0);transform-origin:left;transition:transform .35s;
}
.card:hover{transform:translateY(-6px);box-shadow:0 20px 40px rgba(0,0,0,.08)}
.card:hover::before{transform:scaleX(1)}
.card-icon{
  width:56px;height:56px;border:1.5px solid rgba(184,149,48,.35);border-radius:50%;
  display:flex;align-items:center;justify-content:center;transition:border-color .3s,background .3s;flex-shrink:0;
}
.card:hover .card-icon{border-color:var(--gold);background:rgba(184,149,48,.06)}
.card-icon svg{width:22px;height:22px;stroke:var(--gold);fill:none;stroke-width:1.5}
.card-label{font-size:9px;font-weight:700;letter-spacing:2px;color:var(--text);text-align:center;line-height:1.45}
.card-desc{font-family:var(--font-serif);font-size:15px;color:var(--text-mid);line-height:1.55;text-align:center;flex-grow:1}

/* ═══════════════════════════════════════════
   9. OFFER SECTION
   ═══════════════════════════════════════════ */
.offer{
  background:var(--black);padding:var(--space-lg) 16px var(--space-xl);
  text-align:center;position:relative;overflow:hidden;max-width:100%;
}
.offer::before{
  content:'NR1';position:absolute;right:-10px;top:50%;transform:translateY(-50%);
  font-family:var(--font-serif);font-size:200px;font-weight:300;line-height:1;
  color:rgba(255,255,255,.025);pointer-events:none;
}
.offer::after{
  content:'';position:absolute;top:0;left:20px;right:20px;height:1px;
  background:linear-gradient(90deg,transparent,var(--gold),transparent);
}
.offer-tag{font-size:9px;font-weight:700;letter-spacing:4px;color:var(--red);display:block;margin-bottom:12px;position:relative;z-index:2}
.offer-title{font-family:var(--font-serif);font-size:clamp(28px,7vw,54px);font-weight:400;color:#fff;line-height:1.08;margin-bottom:18px;position:relative;z-index:2}
.offer-title .cg{color:var(--gold-light);font-style:italic}

/* Price card */
.price-card{
  background:linear-gradient(135deg,rgba(184,149,48,.12),rgba(184,149,48,.04));
  border:3px solid var(--gold);padding:44px var(--space-md);max-width:100%;margin:0 auto var(--space-lg);
  position:relative;border-radius:2px;z-index:2;animation:glowPulse 3s ease-in-out infinite;
}
.price-card-badge{
  position:absolute;top:-14px;left:50%;transform:translateX(-50%);
  background:var(--red);color:#fff;font-size:9px;font-weight:700;letter-spacing:2px;
  padding:7px 22px;white-space:nowrap;box-shadow:0 4px 14px rgba(192,57,43,.4);
}
.price-card .price-old{font-family:var(--font-serif);font-size:20px;color:rgba(255,255,255,.3);text-decoration:line-through;display:block;margin-bottom:var(--space-xs)}
.price-card .price-new-wrap{display:flex;align-items:baseline;justify-content:center;gap:var(--space-xs)}
.price-card .price-new{font-family:var(--font-serif);font-size:56px;font-weight:600;color:var(--gold-light);line-height:1}
.price-card .price-new small{font-size:16px;font-weight:400;color:rgba(255,255,255,.35)}
.price-pulse-dot{width:10px;height:10px;background:var(--green);border-radius:50%;display:inline-block;animation:pulseDot 1.5s ease-in-out infinite;margin-left:var(--space-xs);vertical-align:super}
.price-card .price-save{font-size:11px;font-weight:700;letter-spacing:1.5px;color:var(--green);margin-top:10px;display:block}
.price-card .price-installment{font-size:13px;color:rgba(255,255,255,.45);margin-top:var(--space-xs)}

.offer-cta{
  display:inline-flex;align-items:center;gap:14px;
  background:var(--gold);color:#fff;font-size:11px;font-weight:700;letter-spacing:3.5px;
  padding:18px 40px;text-decoration:none;position:relative;overflow:hidden;transition:box-shadow .3s;
  animation:pulse 2.5s ease-in-out infinite;min-height:48px;z-index:2;
}
.offer-cta::before{content:'';position:absolute;inset:0;background:var(--red);transform:translateX(-101%);transition:transform .5s cubic-bezier(.77,0,.18,1)}
.offer-cta:hover::before{transform:translateX(0)}
.offer-cta:hover{box-shadow:0 10px 36px rgba(184,149,48,.4)}
.offer-cta span,.offer-cta svg{position:relative;z-index:1}
.offer-cta svg{width:16px;height:16px;stroke:currentColor;fill:none;stroke-width:2;transition:transform .3s}
.offer-cta:hover svg{transform:translateX(4px)}
.offer-guarantee{display:flex;align-items:center;justify-content:center;gap:8px;font-size:10px;color:rgba(255,255,255,.35);letter-spacing:1px;margin-top:18px;position:relative;z-index:2;flex-wrap:wrap}
.offer-guarantee svg{width:14px;height:14px;stroke:var(--gold);fill:none;stroke-width:1.5}

/* ═══════════════════════════════════════════
   10. TESTIMONIALS
   ═══════════════════════════════════════════ */
.testimonials{background:var(--cream);padding:var(--space-lg) 16px var(--space-xl);text-align:center;max-width:100%}
.testi-grid{display:grid;grid-template-columns:1fr;gap:var(--space-md);max-width:var(--max-w);margin:0 auto;align-items:stretch}
.testi-card{
  background:var(--cream-mid);padding:var(--space-lg) var(--space-md);position:relative;border-radius:2px;
  box-shadow:0 4px 16px rgba(0,0,0,.04);transition:transform .35s,box-shadow .35s;
  border-left:3px solid var(--gold);display:flex;flex-direction:column;text-align:left;
}
.testi-card:hover{transform:translateY(-4px);box-shadow:0 12px 32px rgba(0,0,0,.07)}
.testi-card::before{
  content:'\201C';font-family:var(--font-serif);font-size:36px;color:var(--gold-pale);
  position:absolute;top:10px;left:16px;line-height:1;opacity:.5;
}
.testi-text{font-family:var(--font-serif);font-size:17px;color:var(--text-mid);line-height:1.7;margin-bottom:14px;position:relative;z-index:1;flex-grow:1;padding-top:var(--space-sm)}
.testi-author{font-size:10px;font-weight:700;letter-spacing:2px;color:var(--gold);position:relative;z-index:1}
.testi-role{font-size:11px;color:var(--text-mid);font-style:italic;margin-top:2px;position:relative;z-index:1}

/* ═══════════════════════════════════════════
   11. FAQ
   ═══════════════════════════════════════════ */
.faq{background:var(--cream-mid);padding:var(--space-lg) 16px var(--space-xl);text-align:center;max-width:100%}
.faq-list{max-width:700px;margin:0 auto;text-align:left}
.faq-item{border-bottom:1px solid rgba(184,149,48,.18);transition:border-left .3s}
.faq-item.open{border-left:3px solid var(--gold);padding-left:10px}
.faq-q{
  font-size:13px;font-weight:600;color:var(--text);padding:18px 0;
  cursor:pointer;display:flex;justify-content:space-between;align-items:center;
  gap:var(--space-sm);transition:color .3s;min-height:48px;
}
.faq-q:hover{color:var(--gold)}
.faq-q-num{color:var(--gold);font-size:11px;font-weight:700;margin-right:var(--space-xs);flex-shrink:0}
.faq-q-text{flex:1}
.faq-q svg{width:15px;height:15px;stroke:currentColor;fill:none;stroke-width:2;transition:transform .3s;flex-shrink:0}
.faq-item.open .faq-q svg{transform:rotate(45deg)}
.faq-a{font-family:var(--font-serif);font-size:16px;color:var(--text-mid);line-height:1.7;max-height:0;overflow:hidden;transition:max-height .4s ease,padding .4s ease}
.faq-item.open .faq-a{max-height:400px;padding-bottom:18px}

/* ═══════════════════════════════════════════
   12. FINAL CTA
   ═══════════════════════════════════════════ */
.final-cta{
  background:var(--black);padding:var(--space-lg) 16px var(--space-xl);
  text-align:center;position:relative;overflow:hidden;max-width:100%;
}
.final-cta::before{content:'';position:absolute;top:0;left:20px;right:20px;height:1px;background:linear-gradient(90deg,transparent,var(--gold),transparent)}
.final-cta h2{font-family:var(--font-serif);font-size:clamp(28px,7vw,54px);font-weight:400;color:#fff;line-height:1.08;margin-bottom:18px}
.final-cta .cg{color:var(--gold-light);font-style:italic}
.final-cta p{font-family:var(--font-serif);font-size:17px;color:rgba(255,255,255,.65);line-height:1.7;max-width:560px;margin:0 auto var(--space-lg)}
.final-cta-timer{
  display:inline-flex;align-items:center;gap:var(--space-xs);
  font-size:11px;font-weight:700;letter-spacing:2px;color:var(--red);
  margin-bottom:var(--space-lg);animation:countdown 2s ease-in-out infinite;
}
.final-cta-timer svg{width:16px;height:16px;stroke:currentColor;fill:none;stroke-width:2}

/* Trust badges */
.badges{display:flex;gap:16px;flex-wrap:wrap;justify-content:center;margin-top:var(--space-xl);padding-top:var(--space-lg);border-top:1px solid rgba(255,255,255,.08)}
.badge{display:flex;align-items:center;gap:10px;background:rgba(255,255,255,.04);padding:var(--space-sm) var(--space-md);border-radius:2px}
.badge svg{width:18px;height:18px;stroke:var(--gold);fill:none;stroke-width:1.5;flex-shrink:0}
.badge-txt{font-size:8px;font-weight:600;letter-spacing:1.2px;color:rgba(255,255,255,.5);line-height:1.4;max-width:88px}

/* ═══════════════════════════════════════════
   13. FOOTER
   ═══════════════════════════════════════════ */
.footer{
  background:var(--charcoal);padding:var(--space-lg) 20px;text-align:center;
  font-size:10px;color:rgba(255,255,255,.28);letter-spacing:1px;line-height:1.8;
}
.footer a{color:var(--gold);text-decoration:none;transition:color .3s}
.footer a:hover{color:var(--gold-light)}

/* ═══════════════════════════════════════════
   14. FLOATING MOBILE CTA
   ═══════════════════════════════════════════ */
.floating-cta{
  position:fixed;bottom:0;left:0;right:0;z-index:199;
  background:var(--gold);text-align:center;padding:16px 20px;
  font-size:11px;font-weight:700;letter-spacing:2.5px;color:#fff;
  text-decoration:none;display:none;
  box-shadow:0 -4px 20px rgba(0,0,0,.2);transition:transform .4s ease;
  transform:translateY(100%);
  padding-bottom:calc(16px + env(safe-area-inset-bottom,0px));
}
.floating-cta.visible{transform:translateY(0)}

/* ═══════════════════════════════════════════
   TABLET — min-width: 601px
   ═══════════════════════════════════════════ */
@media(min-width:601px){
  .urgency-bar{font-size:12px;letter-spacing:2.5px}
  .hero{padding:var(--space-xl) var(--space-md) var(--space-lg)}
  .hero-inner{flex-direction:row;align-items:center;gap:var(--space-xl)}
  .hero-left-col{flex:1;min-width:0}
  .hero-right{display:block;flex:1;min-height:540px}
  .hero-book-mobile{display:none}
  .hero-person-mobile{display:none}
  .hero-logo{width:280px}
  .hero-nr1{font-size:clamp(80px,9vw,140px)}
  .price-block{max-width:360px}
  .price-new{font-size:52px}

  .proof-bar{grid-template-columns:repeat(4,1fr);gap:var(--space-md);padding:var(--space-lg) var(--space-md)}
  .proof-number{font-size:36px}
  .proof-label{font-size:9px}

  .problem{padding:var(--space-xl) var(--space-md)}
  .problem-grid{grid-template-columns:1fr;max-width:600px}
  .problem .sec-tag{font-size:9.5px;letter-spacing:5px}
  .problem-footer{font-size:19px}

  .quote-band{padding:var(--space-lg) var(--space-md);gap:var(--space-lg)}
  .qb-sep{width:2px;height:90px;background:linear-gradient(180deg,transparent,var(--gold),transparent)}

  .about{padding:var(--space-xl) var(--space-md)}
  .about-photo-mobile{display:none}
  .about-photo{display:block}
  .about-grid{display:grid;grid-template-columns:280px 1fr;gap:var(--space-lg);align-items:start}
  .about-benefits{grid-column:1/-1;padding-top:var(--space-md)}

  .book-section{padding:var(--space-xl) var(--space-md)}
  .book-img-wrap img{max-width:380px}

  .cards-section{padding:var(--space-xl) var(--space-md)}
  .cards-grid{grid-template-columns:repeat(2,1fr)}

  .offer{padding:var(--space-xl) var(--space-md)}
  .offer::before{font-size:260px}
  .price-card{max-width:480px;padding:48px var(--space-lg)}
  .price-card .price-new{font-size:64px}

  .testimonials{padding:var(--space-xl) var(--space-md)}
  .testi-grid{grid-template-columns:repeat(2,1fr)}

  .faq{padding:var(--space-xl) var(--space-md)}
  .final-cta{padding:var(--space-xl) var(--space-md)}
  .footer{padding:var(--space-lg) var(--space-md)}
}

/* ═══════════════════════════════════════════
   DESKTOP — min-width: 961px
   ═══════════════════════════════════════════ */
@media(min-width:961px){
  .hero{
    min-height:100vh;padding:0;
    display:grid;grid-template-columns:1fr 1fr;
    max-width:1400px;margin:0 auto;
  }
  .hero::after{
    content:'';position:absolute;top:0;right:0;width:50%;height:100%;
    background:linear-gradient(155deg,#EDE5D4 0%,#E5DBC8 55%,#DDD1B8 100%);z-index:0;
  }
  .hero-inner{display:contents}
  .hero-left-col{
    padding:var(--space-xl) var(--space-lg) var(--space-xl) 80px;
    display:flex;flex-direction:column;justify-content:center;
    position:relative;z-index:3;gap:var(--space-sm);
  }
  .hero-right{
    display:flex!important;align-items:flex-end;justify-content:flex-end;
    padding:0;position:relative;z-index:2;min-height:100vh;flex:none;
  }

  .proof-bar{padding:var(--space-lg) 80px;flex-wrap:nowrap;display:flex;gap:0}
  .proof-item{padding:0 40px}
  .proof-item+.proof-item::before{content:'';position:absolute;left:0;top:20%;height:60%;width:1px;background:rgba(184,149,48,.25)}

  .problem{padding:var(--space-2xl) 80px}
  .problem-grid{grid-template-columns:repeat(3,1fr)}

  .quote-band{grid-template-columns:1fr 2px 1.7fr;padding:var(--space-xl) 80px;gap:var(--space-xl)}
  .qb-sep{display:block!important;width:2px;height:110px}

  .about{padding:var(--space-2xl) 80px;display:grid;grid-template-columns:320px 1fr 1fr;gap:var(--space-xl);align-items:start}
  .about-grid{display:contents}
  .about-benefits{grid-column:auto;padding-top:44px}

  .book-section{grid-template-columns:1fr 1fr;padding:var(--space-2xl) 80px;gap:var(--space-xl);display:grid;align-items:center}
  .book-img-wrap img{max-width:480px}
  .book-img-wrap::after{
    content:'';position:absolute;top:8px;left:calc(50% - 240px + 8px);
    width:calc(100% - 16px);max-width:464px;height:100%;
    border:2px solid var(--gold-pale);border-radius:6px;z-index:-1;
    transition:top .5s,border-color .5s;pointer-events:none;
  }
  .book-img-wrap:hover::after{top:14px;border-color:var(--gold)}

  .cards-section{padding:var(--space-2xl) 80px}
  .cards-grid{grid-template-columns:repeat(3,1fr)}

  .offer{padding:var(--space-2xl) 80px}
  .offer::before{font-size:340px}
  .offer::after{left:80px;right:80px}
  .price-card .price-new{font-size:72px}

  .testimonials{padding:var(--space-2xl) 80px}
  .testi-grid{grid-template-columns:repeat(3,1fr)}

  .faq{padding:var(--space-2xl) 80px}
  .final-cta{padding:var(--space-2xl) 80px}
  .final-cta::before{left:80px;right:80px}
  .footer{padding:var(--space-lg) 80px}
}

/* ═══════════════════════════════════════════
   FLOATING CTA — mobile only
   ═══════════════════════════════════════════ */
@media(max-width:600px){
  .floating-cta{display:block}
}

/* ═══════════════════════════════════════════
   ACCESSIBILITY & REDUCED MOTION
   ═══════════════════════════════════════════ */
@media(prefers-reduced-motion:reduce){
  *,*::before,*::after{animation-duration:.01ms!important;animation-iteration-count:1!important;transition-duration:.01ms!important}
  .sr,.sr-left,.sr-right{opacity:1;transform:none}
}
:focus-visible{outline:2px solid var(--gold);outline-offset:2px}

/* ═══════════════════════════════════════════
   WORD-BREAK SAFETY
   ═══════════════════════════════════════════ */
.problem-card p,.testi-text,.faq-a,.hero-desc,.book-contents li,.card-desc,.qb-right p{word-break:break-word;overflow-wrap:break-word}

/* ═══════════════════════════════════════════
   OVERFLOW GUARD
   ═══════════════════════════════════════════ */
html,body{overflow-x:hidden;width:100%}
section,div,header,footer,main,article,aside{max-width:100vw}
.hi-sep{flex-shrink:0}
</style>
</head>
<body>

<!-- ═══════════════════════════════════════
     1. URGENCY BAR
     ═══════════════════════════════════════ -->
<div class="urgency-bar" role="alert">
  ATENÇÃO: A fiscalização punitiva da nova NR1 começa em <em>MAIO DE 2026</em> — Prepare-se agora!
</div>

<!-- ═══════════════════════════════════════
     2. HERO
     ═══════════════════════════════════════ -->
<section class="hero" id="hero">
  <div class="hero-inner">
    <div class="hero-left-col">
      <!-- Logo -->
      <div class="hero-logo">
        <a href="https://pay.kiwify.com.br/Od1jddC" aria-label="Comprar NR1 Além da Norma">
          <img src="assets/logo.png" alt="Katti Elleres — Logo" width="200" height="60">
        </a>
      </div>

      <!-- Mobile person avatar -->
      <div class="hero-person-mobile">
        <img src="assets/hero-person.png" alt="Katti Elleres" width="52" height="52">
        <span>Katti Elleres<small>Especialista em Liderança Humanizada</small></span>
      </div>

      <!-- Urgency badge -->
      <div class="hero-badge">
        <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        PRAZO ATÉ MAIO DE 2026
      </div>

      <!-- Title -->
      <div class="hero-title">
        <h1 class="hero-nr1">NR1 <span>além</span></h1>
        <div class="hero-subtitle">DA NORMA&trade;</div>
      </div>
      <div class="gold-bar"></div>

      <!-- Description -->
      <p class="hero-desc">
        A nova NR1 tornou obrigatória a gestão de riscos psicossociais — com <strong>multas de até R$&nbsp;805 por trabalhador</strong>. Este livro é o seu guia prático para proteger sua empresa e sua equipe.
      </p>

      <!-- Price block -->
      <div class="price-block">
        <div class="price-old">R$ 90,00</div>
        <div class="price-new">R$ 45,00 <small>pagamento único · acesso imediato</small></div>
        <div class="price-save">VOCÊ ECONOMIZA 50%</div>
      </div>

      <!-- Trust icons -->
      <div class="hero-icons">
        <div class="hi-item">
          <div class="hi-circle">
            <svg viewBox="0 0 24 24"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
          </div>
          <span class="hi-label">COMPRA SEGURA</span>
        </div>
        <div class="hi-sep"></div>
        <div class="hi-item">
          <div class="hi-circle">
            <svg viewBox="0 0 24 24"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
          </div>
          <span class="hi-label">ACESSO IMEDIATO</span>
        </div>
        <div class="hi-sep"></div>
        <div class="hi-item">
          <div class="hi-circle">
            <svg viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <span class="hi-label">7 DIAS DE GARANTIA</span>
        </div>
      </div>

      <!-- CTA -->
      <div class="cta-wrap">
        <a href="https://pay.kiwify.com.br/Od1jddC" class="cta" role="button">
          <span>QUERO ME PREPARAR</span>
          <svg viewBox="0 0 24 24"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
        <div class="cta-sub">Ou em até 6x de R$&nbsp;8,16 sem juros</div>
      </div>
    </div>

    <!-- Desktop hero right -->
    <div class="hero-right">
      <img class="hero-person" src="assets/hero-person.png" alt="Katti Elleres — Especialista em Liderança Humanizada" width="600" height="800">
      <img class="hero-book" src="assets/hero-book.png" alt="Livro NR1 Além da Norma" width="300" height="400">
    </div>

    <!-- Mobile book image -->
    <div class="hero-book-mobile">
      <img src="assets/hero-book.png" alt="Livro NR1 Além da Norma" width="280" height="380">
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════
     3. SOCIAL PROOF BAR
     ═══════════════════════════════════════ -->
<section class="proof-bar sr" aria-label="Números e garantias">
  <div class="proof-item">
    <div class="proof-number">2.000+</div>
    <div class="proof-label">LÍDERES IMPACTADOS</div>
  </div>
  <div class="proof-item">
    <div class="proof-number">50%</div>
    <div class="proof-label">DESCONTO EXCLUSIVO</div>
  </div>
  <div class="proof-item">
    <div class="proof-number">7 dias</div>
    <div class="proof-label">GARANTIA INCONDICIONAL</div>
  </div>
  <div class="proof-item">
    <div class="proof-number">2026</div>
    <div class="proof-label">PRAZO PARA ADEQUAÇÃO</div>
  </div>
</section>

<!-- ═══════════════════════════════════════
     4. PROBLEM SECTION (DOR)
     ═══════════════════════════════════════ -->
<section class="problem" id="problema">
  <span class="sec-tag sr">VOCÊ SABIA?</span>
  <h2 class="sec-title sr d1">Sua empresa pode ser multada<br>a partir de maio de 2026</h2>
  <div class="sec-line sr d2"></div>

  <div class="problem-grid">
    <!-- Card 1 -->
